#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &totem_physical_layout;
    };

    totem_physical_layout: totem_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "TOTEM";
        transform = <&default_transform>;
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100   85  149 (-1000)   135  199>
            , <&key_physical_attrs 100 100  200   61  (-400)   250  111>
            , <&key_physical_attrs 100 100  316    3      0      0    0>
            , <&key_physical_attrs 100 100  418   51      0      0    0>
            , <&key_physical_attrs 100 100  520   66      0      0    0>
            , <&key_physical_attrs 100 100  847   66      0      0    0>
            , <&key_physical_attrs 100 100  949   51      0      0    0>
            , <&key_physical_attrs 100 100 1051    3      0      0    0>
            , <&key_physical_attrs 100 100 1166   61    400   1216  111>
            , <&key_physical_attrs 100 100 1282  149   1000   1332  199>
            , <&key_physical_attrs 100 100  102  244 (-1000)   152  294>
            , <&key_physical_attrs 100 100  206  157  (-400)   256  207>
            , <&key_physical_attrs 100 100  316  100      0      0    0>
            , <&key_physical_attrs 100 100  418  148      0      0    0>
            , <&key_physical_attrs 100 100  520  163      0      0    0>
            , <&key_physical_attrs 100 100  847  163      0      0    0>
            , <&key_physical_attrs 100 100  949  148      0      0    0>
            , <&key_physical_attrs 100 100 1051  100      0      0    0>
            , <&key_physical_attrs 100 100 1160  157    400   1210  207>
            , <&key_physical_attrs 100 100 1264  244   1000   1314  294>
            , <&key_physical_attrs 100 100   10  314 (-1000)    60  364>
            , <&key_physical_attrs 100 100  119  339 (-1000)   169  389>
            , <&key_physical_attrs 100 100  213  253  (-400)   263  303>
            , <&key_physical_attrs 100 100  316  197      0      0    0>
            , <&key_physical_attrs 100 100  418  244      0      0    0>
            , <&key_physical_attrs 100 100  520  259      0      0    0>
            , <&key_physical_attrs 100 100  847  259      0      0    0>
            , <&key_physical_attrs 100 100  949  244      0      0    0>
            , <&key_physical_attrs 100 100 1051  197      0      0    0>
            , <&key_physical_attrs 100 100 1154  253    400   1204  303>
            , <&key_physical_attrs 100 100 1248  339   1000   1298  389>
            , <&key_physical_attrs 100 100 1356  314   1000   1406  364>
            , <&key_physical_attrs 100 100  390  361      0      0    0>
            , <&key_physical_attrs 100 100  502  376   1500    552  426>
            , <&key_physical_attrs 100 100  608  419   3000    658  469>
            , <&key_physical_attrs 100 100  758  419 (-3000)   808  469>
            , <&key_physical_attrs 100 100  864  376 (-1500)   914  426>
            , <&key_physical_attrs 100 100  978  361      0      0    0>
        ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
//             | SW01  | SW02  | SW03  | SW04  | SW05  |  | SW05  | SW04  | SW03  | SW02  | SW01  |
//             | SW06  | SW07  | SW08  | SW09  | SW10  |  | SW10  | SW09  | SW08  | SW07  | SW06  | 
//      | SW16 | SW11  | SW12  | SW13  | SW14  | SW15  |  | SW15  | SW14  | SW13  | SW12  | SW11  | SW16  |
//                             | SW17  | SW18  | SW19  |  | SW19  | SW18  | SW17  | 
        map = <
                RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
                RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
        RC(3,0) RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(3,9)
                                RC(3,2) RC(3,3) RC(3,4)    RC(3,5) RC(3,6) RC(3,7)         
        >;
    };


    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row"; 
        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };
};